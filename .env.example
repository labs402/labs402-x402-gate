# =============================================================================
# labs402-x402-gate — variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commits el archivo .env. Ya esta en .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVIDOR — wallet que RECIBE los pagos USDC
# Esta es la clave publica de tu wallet. No es secreta.
# Ejemplo: 7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU
# -----------------------------------------------------------------------------
SOLANA_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# CLIENTE — clave privada de la wallet que PAGA el servicio
# Phantom: Configuracion > Seguridad y privacidad > Mostrar clave privada
# Formato aceptado: base58 (Phantom) o array JSON de 64 bytes (solana-keygen)
#
# ADVERTENCIA: esta variable da control total sobre los fondos de esa wallet.
# Usa una wallet dedicada para desarrollo con un saldo minimo ($1-5 USDC).
# NUNCA uses tu wallet principal.
# -----------------------------------------------------------------------------
SOLANA_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# FACILITATOR — servicio que verifica y liquida los pagos on-chain
#
# Mainnet — Coinbase CDP (recomendado):
#   URL: https://api.cdp.coinbase.com/platform/v2/x402
#   Crear cuenta en: https://portal.cdp.coinbase.com/access/api
#   Free tier: 1,000 tx/mes. Despues: $0.001/tx.
#
# Alternativa publica sin cuenta (para pruebas iniciales):
#   URL: https://facilitator.payai.network
#
# Testnet (devnet Solana, sin dinero real):
#   URL: https://x402.org/facilitator
# -----------------------------------------------------------------------------
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# -----------------------------------------------------------------------------
# CONFIGURACION DEL SERVIDOR
# -----------------------------------------------------------------------------
PORT=8000

# -----------------------------------------------------------------------------
# CONFIGURACION DEL CLIENTE
# URL del servidor al que el cliente va a pagar
# -----------------------------------------------------------------------------
SERVIDOR_URL=http://localhost:8000
