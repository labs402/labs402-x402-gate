# =============================================================================
# x402-scraper-gate — variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA hagas commit del archivo .env. Ya esta en .gitignore.
# =============================================================================

# Wallet que RECIBE los pagos USDC (clave publica, no es secreta)
# Ejemplo: 7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU
SOLANA_WALLET_ADDRESS=

# Clave privada de la wallet que PAGA las consultas en el demo
# Phantom: Configuracion > Seguridad y privacidad > Mostrar clave privada
# Formato: base58 (Phantom) o array JSON de 64 bytes (solana-keygen)
# ADVERTENCIA: da control total sobre los fondos. Usa una wallet de desarrollo.
SOLANA_PRIVATE_KEY=

# Facilitator que verifica y liquida los pagos on-chain
# Coinbase CDP (recomendado, 1000 tx/mes gratis): https://portal.cdp.coinbase.com/access/api
# Alternativa publica sin cuenta (para pruebas): https://facilitator.payai.network
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# URL del servidor (para el cliente demo)
SERVIDOR_URL=http://localhost:8000
